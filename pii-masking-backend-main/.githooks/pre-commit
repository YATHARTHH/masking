#!/usr/bin/env bash
# =============================================================================
# DevHub Security Gate — Pre-Commit Hook
# Activated via: bash tasks/mise-install.sh (macOS/Linux/Git Bash)
#                .\tasks\mise-install.cmd   (Windows PowerShell)
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

# On Windows a git hook can be launched (e.g. by a GUI client or IDE) with an
# empty PATHEXT. Without it, mise cannot resolve `python` -> `python.exe` and
# fails with "cannot find binary path". Provide a sane default when unset.
export PATHEXT="${PATHEXT:-.COM;.EXE;.BAT;.CMD;.VBS;.JS;.WS;.MSC}"

find_mise_in_winget() {
  local bases=()
  bases+=("$HOME/AppData/Local")

  if [ -n "${LOCALAPPDATA:-}" ]; then
    local local_app_data="$LOCALAPPDATA"
    if command -v cygpath &>/dev/null; then
      local_app_data="$(cygpath -u "$LOCALAPPDATA")"
    fi
    bases+=("$local_app_data")
  fi

  local base link packages found
  for base in "${bases[@]}"; do
    link="$base/Microsoft/WinGet/Links/mise.exe"
    if [ -x "$link" ]; then
      MISE_BIN="$link"
      return 0
    fi

    packages="$base/Microsoft/WinGet/Packages"
    if [ -d "$packages" ] && command -v find &>/dev/null; then
      found="$(find "$packages" -iname mise.exe -type f 2>/dev/null | head -n 1 || true)"
      if [ -n "$found" ] && [ -x "$found" ]; then
        MISE_BIN="$found"
        return 0
      fi
    fi
  done

  return 1
}

MISE_BIN=""
if command -v mise &>/dev/null; then
  MISE_BIN="$(command -v mise)"
elif [ -x "$HOME/.local/bin/mise" ]; then
  MISE_BIN="$HOME/.local/bin/mise"
else
  find_mise_in_winget || true
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT" || exit 1
export PRE_COMMIT_HOME="${PRE_COMMIT_HOME:-$HOME/.pre-commit-cache}"
mkdir -p "$PRE_COMMIT_HOME"

# ── Refuse commit when repo-local hooks are not active ────────────────────────
CURRENT_HOOKS_PATH=$(git config --get core.hooksPath 2>/dev/null || echo "")
if [ "$CURRENT_HOOKS_PATH" != ".githooks" ]; then
  echo ""
  echo -e "${RED}${BOLD}  COMMIT BLOCKED — security hooks are not activated.${NC}"
  echo ""
  echo -e "${YELLOW}  Run: bash tasks/mise-install.sh  (macOS/Linux/Git Bash)"
  echo -e "       .\\tasks\\mise-install.cmd   (Windows PowerShell)${NC}"
  echo ""
  exit 1
fi

# ── Run pre-commit framework when available (shows pass/fail per hook) ─────────
# Tries: pre-commit binary → python -m pre_commit → python3 -m pre_commit → mise exec
if [ -f ".pre-commit-config.yaml" ]; then
  PRE_COMMIT_CMD=""
  if [ -n "$MISE_BIN" ]; then
    # Trust this repo's mise config so tools load in a non-interactive hook.
    # An untrusted config silently disables python/gitleaks for `mise exec`.
    "$MISE_BIN" trust &>/dev/null 2>&1 || true
    # Prefer the module form (python -m pre_commit): it runs through the same
    # interpreter that pip-installed pre-commit and does NOT depend on the
    # pre-commit console script being on PATH — so it works identically on a
    # fresh clone, from a new terminal, or from a GUI/IDE git client.
    if "$MISE_BIN" exec -- python -m pre_commit --version &>/dev/null 2>&1; then
      PRE_COMMIT_CMD="$MISE_BIN exec -- python -m pre_commit"
    fi
  fi
  if [ -z "$PRE_COMMIT_CMD" ] && command -v pre-commit &>/dev/null; then
    PRE_COMMIT_CMD="pre-commit"
  fi
  if [ -z "$PRE_COMMIT_CMD" ] && command -v python &>/dev/null && python -m pre_commit --version &>/dev/null 2>&1; then
    PRE_COMMIT_CMD="python -m pre_commit"
  fi
  if [ -z "$PRE_COMMIT_CMD" ] && command -v python3 &>/dev/null && python3 -m pre_commit --version &>/dev/null 2>&1; then
    PRE_COMMIT_CMD="python3 -m pre_commit"
  fi

  if [ -n "$PRE_COMMIT_CMD" ]; then
    PRE_COMMIT_STATUS=0
    $PRE_COMMIT_CMD run --hook-stage pre-commit || PRE_COMMIT_STATUS=$?
    if [ "$PRE_COMMIT_STATUS" = "0" ]; then
      echo -e "${GREEN}  ✅ All checks passed.${NC}"
      exit 0
    fi
    echo ""
    echo -e "${RED}${BOLD}  🚨 COMMIT BLOCKED — one or more checks failed (see above).${NC}"
    echo ""
    exit 1
  fi
fi

# ── Fallback: run gitleaks + CODEOWNERS check directly ────────────────────────
# Used when pre-commit framework is not installed.

# Locate gitleaks
GITLEAKS=()
if command -v gitleaks &>/dev/null; then
  GITLEAKS=("gitleaks")
elif [ -x "$HOME/AppData/Local/mise/shims/gitleaks.exe" ]; then
  GITLEAKS=("$HOME/AppData/Local/mise/shims/gitleaks.exe")
elif [ -n "${LOCALAPPDATA:-}" ]; then
  LOCAL_APP_DATA="$LOCALAPPDATA"
  if command -v cygpath &>/dev/null; then
    LOCAL_APP_DATA="$(cygpath "$LOCALAPPDATA")"
  fi
  if [ -x "$LOCAL_APP_DATA/mise/shims/gitleaks.exe" ]; then
    GITLEAKS=("$LOCAL_APP_DATA/mise/shims/gitleaks.exe")
  fi
fi
if [ -z "${GITLEAKS[0]:-}" ] && [ -n "$MISE_BIN" ]; then
  GITLEAKS=("$MISE_BIN" exec -- gitleaks)
fi
if [ -z "${GITLEAKS[0]:-}" ]; then
  echo ""
  echo -e "${RED}${BOLD}  COMMIT BLOCKED — gitleaks not found.${NC}"
  echo -e "${YELLOW}  Run setup to install: bash tasks/mise-install.sh  or  .\\tasks\\mise-install.cmd${NC}"
  echo ""
  exit 1
fi

# Check CODEOWNERS
if [ ! -f ".github/CODEOWNERS" ]; then
  echo ""
  echo -e "${RED}${BOLD}  COMMIT BLOCKED — .github/CODEOWNERS is missing.${NC}"
  echo -e "${YELLOW}  Create it with at least one owner:  * @your-github-username${NC}"
  echo ""
  exit 1
fi

echo -e "${YELLOW}  Scanning staged files for secrets...${NC}"
SCAN_FAILED=0

# Pass 1 — UTF-8 / ASCII
if ! "${GITLEAKS[@]}" protect --staged --config .gitleaks.toml --redact --verbose --no-banner 2>/dev/null; then
  SCAN_FAILED=1
fi

# Pass 2 — UTF-16 (PowerShell default encoding)
if [ "$SCAN_FAILED" = "0" ]; then
  PYTHON=""
  if command -v python &>/dev/null; then PYTHON="python"
  elif command -v python3 &>/dev/null; then PYTHON="python3"
  fi
  if [ -n "$PYTHON" ]; then
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
    while IFS= read -r staged_file; do
      [ -f "$staged_file" ] || continue
      IS_UTF16=$("$PYTHON" -c "
import sys
with open(sys.argv[1], 'rb') as f:
    bom = f.read(2)
print('yes' if bom in (b'\xff\xfe', b'\xfe\xff') else 'no')
" "$staged_file" 2>/dev/null || echo "no")
      if [ "$IS_UTF16" = "yes" ]; then
        UTF8_CONTENT=$("$PYTHON" -c "
import sys
with open(sys.argv[1], 'rb') as f:
    raw = f.read()
if raw[:2] == b'\xff\xfe':
    text = raw[2:].decode('utf-16-le', errors='replace')
elif raw[:2] == b'\xfe\xff':
    text = raw[2:].decode('utf-16-be', errors='replace')
else:
    text = raw.decode('utf-8', errors='replace')
sys.stdout.write(text)
" "$staged_file" 2>/dev/null || true)
        if [ -n "$UTF8_CONTENT" ]; then
          if ! echo "$UTF8_CONTENT" | "${GITLEAKS[@]}" detect --pipe --config .gitleaks.toml --redact --no-banner 2>/dev/null; then
            echo -e "${RED}${BOLD}  🚨 Secret in UTF-16 file: $staged_file${NC}"
            SCAN_FAILED=1
          fi
        fi
      fi
    done <<< "$STAGED_FILES"
  fi
fi

if [ "$SCAN_FAILED" = "1" ]; then
  echo ""
  echo -e "${RED}${BOLD}  🚨 COMMIT BLOCKED — secrets detected.${NC}"
  echo ""
  echo -e "${YELLOW}  → Remove the secret and use a secret manager or environment variables."
  echo -e "  → If already pushed, revoke the secret immediately."
  echo -e "  → For a false positive, add an allowlist entry to .gitleaks.toml${NC}"
  echo ""
  exit 1
fi

echo -e "${GREEN}  ✅ Security check passed.${NC}"
exit 0
